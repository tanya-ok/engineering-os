# engineering-os environment. Copy to .env and adjust.
# Every value has a working default; nothing here is required for the demo vault.

# Path to your primary Obsidian vault (defaults to the in-repo template)
EOS_VAULT_PATH=./vault-template

# Where the SQLite index lives
EOS_INDEX_DB=~/.engineering-os/index.db

# Search server bind
EOS_SERVER_HOST=127.0.0.1
EOS_SERVER_PORT=8765

# Embedding model (any sentence-transformers model id)
# Multilingual alternative: paraphrase-multilingual-mpnet-base-v2 (768 dim, larger)
EOS_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
